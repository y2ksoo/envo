[Unit]
Description=Envo English Learning Backend
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/envo/backend
ExecStart=/home/pi/envo/backend/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000 --workers 2
Restart=on-failure
RestartSec=5
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=/home/pi/envo/backend/.env

[Install]
WantedBy=multi-user.target
