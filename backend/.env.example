# ============================================================
# Envo 환경설정 - 이 파일을 복사하여 .env 로 저장하세요
# cp .env.example .env
# ============================================================

# [필수] Anthropic API 키 (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-여기에_키_입력

# ============================================================
# 로컬 개발 (Mac/Linux) - 상대경로 사용, 기본값이므로 생략 가능
# ============================================================
# DATABASE_URL=sqlite:///./data/envo.db
# UPLOAD_DIR=./uploads

# ============================================================
# 라즈베리파이 배포 - 절대경로 사용
# ============================================================
# DATABASE_URL=sqlite:////home/pi/envo/data/envo.db
# UPLOAD_DIR=/home/pi/envo/backend/uploads

# ============================================================
# 선택 설정
# ============================================================
# DAILY_REVIEW_LIMIT=20
# MAX_UPLOAD_SIZE_MB=10
